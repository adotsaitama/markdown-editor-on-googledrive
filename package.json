{
  "name": "drive-markdown-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Google Drive-integrated Markdown editor (Phase 1: launch from Drive + read-only preview)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
